#!/usr/bin/env bash
#
# Local lint helper. Used by .git/hooks/pre-commit and as a standalone entry
# point to keep formatting consistent before committing.
#
# Returns 0 on success, non-zero when a fixable issue is found so the commit
# is rejected. When neither `mix` nor `bundle exec rubocop` are available,
# this script exits 0 with a warning so commits can proceed in restricted
# environments (e.g. containers without the Elixir/Ruby toolchain).
#

set -euo pipefail

if [ "${1:-}" = "--staged" ]; then
    staged="$(git diff --cached --name-only --diff-filter=ACM || true)"
else
    staged=""
fi

run_mix_format() {
    if [ -n "$staged" ]; then
        elixir_files="$(printf '%s\n' "$staged" | grep -E '\.(ex|exs|heex)$' || true)"
        if [ -n "$elixir_files" ]; then
            printf '%s\n' "$elixir_files" | xargs mix format
            printf '%s\n' "$elixir_files" | xargs git add
        fi
    fi
    mix format --check-formatted
}

if command -v mix >/dev/null 2>&1; then
    echo "Running mix format..."
    run_mix_format
elif command -v bundle >/dev/null 2>&1 && [ -f Gemfile ]; then
    echo "Running bundle exec rubocop..."
    bundle exec rubocop "$@"
else
    echo "Warning: no Elixir or Ruby linter available; skipping lint check"
    exit 0
fi